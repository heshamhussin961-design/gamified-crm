# ==================== Supabase ====================
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_role_key_here

# ==================== WhatsApp Business API ====================
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_ID=your_phone_number_id
WHATSAPP_TOKEN=your_access_token
WHATSAPP_APP_SECRET=your_whatsapp_app_secret
WHATSAPP_VERIFY_TOKEN=alsaeb_crm_verify

# ==================== AI Agent ====================
OPENAI_API_KEY=your_openai_key_or_claude_key
AI_MODEL=gpt-4o-mini

# ==================== Stripe Billing (optional) ====================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ==================== Facebook Lead Ads Webhook ====================
FB_VERIFY_TOKEN=alsaeb_crm_verify
FB_APP_SECRET=your_facebook_app_secret
FB_PAGE_ACCESS_TOKEN=your_page_access_token

# ==================== Flask ====================
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change_this_to_a_random_secret

# ==================== GPS / Geofence (Attendance) ====================
OFFICE_LAT=25.2048
OFFICE_LNG=55.2708
OFFICE_RADIUS_METERS=200
REQUIRE_GPS_CHECKIN=false

# ==================== SMTP Email Notifications ====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=AlSaeb CRM <your@gmail.com>

# ==================== Observability / Logging ====================
# LOG_LEVEL: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Sentry: leave empty to disable. Set DSN to enable error tracking.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_RELEASE=git-sha-here

# ==================== Rate Limiting ====================
# memory: per-worker (fast, but multiplies by worker count)
# db:     authoritative across workers via check_rate_limit RPC — use in production
RATE_LIMIT_BACKEND=memory

# ==================== Storage Backup (scripts/backup_storage.py) ====================
BACKUP_OUTPUT_DIR=./backups
BACKUP_BUCKET=alsaeb-docs
BACKUP_KEEP_DAYS=14
